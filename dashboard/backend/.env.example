# ── Server ────────────────────────────────────────────────────────────────────
PORT=3001
# Set to your public frontend URL (or * to allow all origins)
FRONTEND_URL=*
# Set to your public backend URL (used in GitHub OAuth redirect)
BACKEND_URL=http://localhost:3001

# ── Security ──────────────────────────────────────────────────────────────────
# Sign JWT tokens — REQUIRED, generate with: openssl rand -hex 32
JWT_SECRET=change_this_to_a_long_random_secret

# Shared secret between n8n HTTP Request nodes and this backend
# Must match x-webhook-secret header set in all three n8n HTTP Request nodes
# Generate with: openssl rand -hex 32
N8N_WEBHOOK_SECRET=change_this_to_a_random_secret

# ── Storage ───────────────────────────────────────────────────────────────────
# NAS path (container-internal):  /nas/data
# NAS path (host):                /n8n_data/Website-Generator/dashboard-data
# Local dev / Render fallback:    leave empty (uses server/data/ automatically)
DATA_DIR=

# Generated project files — shared volume with n8n
# NAS path (container-internal):  /nas/projects
# NAS path (host):                /n8n_data/Website-Generator/projects
# Local dev / Render fallback:    leave empty (uses <repo-root>/projects/)
PROJECTS_DIR=

# Explicit DB path — if empty, derived from DATA_DIR
DB_PATH=

# Additional storage directories (all optional — derived from DATA_DIR when empty)
UPLOADS_DIR=
PREVIEW_DIR=
WORDPRESS_DIR=
MOBILE_DIR=
LOG_DIR=
BACKUP_DIR=
TEMP_DIR=
CACHE_DIR=
EXPORT_DIR=

# n8n data directories (read-only, NAS only)
N8N_DATA_DIR=
N8N_WORKFLOWS_DIR=
N8N_CREDENTIALS_DIR=

# ── n8n Integration ───────────────────────────────────────────────────────────
N8N_CHAT_URL=https://your-n8n-domain.com/webhook/YOUR_WEBHOOK_ID/chat
N8N_MOBILE_CHAT_URL=
N8N_API_KEY=

# ── Email (optional — Resend HTTP API) ────────────────────────────────────────
SMTP_USER=resend
SMTP_PASS=re_your_resend_api_key
SMTP_FROM=onboarding@resend.dev
# Set to true to skip email verification (useful until SMTP is configured)
SKIP_EMAIL_VERIFICATION=true

# ── GitHub (optional) ─────────────────────────────────────────────────────────
GITHUB_TOKEN=ghp_your_personal_access_token
GITHUB_OWNER=your_github_username
GITHUB_REPO=your_repository_name
GITHUB_BRANCH=main

# GitHub OAuth App (optional — for per-user GitHub account linking)
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# ── FTP (optional — for WordPress deployment) ─────────────────────────────────
FTP_HOST=ftp.your-easywp-domain.com
FTP_USER=your_ftp_username
FTP_PASS=your_ftp_password
FTP_REMOTE_PATH=/wp-content/themes
