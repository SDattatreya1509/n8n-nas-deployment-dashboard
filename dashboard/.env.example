# ── NAS Deployment Environment Variables ─────────────────────────────────────
# Copy this file to .env and fill in the values before running docker-compose.
# These values are set in docker-compose.nas.yml environment section.
# Only edit this file if you are running Node directly (not via Docker).

# ── Security ──────────────────────────────────────────────────────────────────
# REQUIRED — generate with: openssl rand -hex 32
JWT_SECRET=CHANGE_THIS_BEFORE_DEPLOYING

# Shared secret between n8n HTTP Request nodes and this backend
# Must match x-webhook-secret header set in all three n8n HTTP Request nodes
# Generate with: openssl rand -hex 32
N8N_WEBHOOK_SECRET=change_this_to_a_random_secret

# ── Network ───────────────────────────────────────────────────────────────────
PORT=3001
FRONTEND_URL=https://your-cloudflare-tunnel-url.com
BACKEND_URL=https://your-cloudflare-tunnel-url.com

# ── Storage — NAS paths ───────────────────────────────────────────────────────
DATA_DIR=/n8n_data/Website-Generator/dashboard-data
PROJECTS_DIR=/n8n_data/Website-Generator/projects
DB_PATH=/n8n_data/Website-Generator/dashboard-data/db.json

UPLOADS_DIR=/n8n_data/Website-Generator/uploads
PREVIEW_DIR=/n8n_data/Website-Generator/previews
WORDPRESS_DIR=/n8n_data/Website-Generator/wordpress
MOBILE_DIR=/n8n_data/Website-Generator/mobile-apps
LOG_DIR=/n8n_data/Website-Generator/dashboard-data/logs
BACKUP_DIR=/n8n_data/Website-Generator/backups
TEMP_DIR=/n8n_data/Website-Generator/shared/temp
CACHE_DIR=/n8n_data/Website-Generator/shared/cache
EXPORT_DIR=/n8n_data/Website-Generator/shared/exports

# n8n data directories (read-only from dashboard)
N8N_DATA_DIR=/n8n_data/Website-Generator/n8n/data
N8N_WORKFLOWS_DIR=/n8n_data/Website-Generator/n8n/workflows
N8N_CREDENTIALS_DIR=/n8n_data/Website-Generator/n8n/credentials

# ── n8n Integration ───────────────────────────────────────────────────────────
N8N_CHAT_URL=https://your-n8n-instance/webhook/YOUR_WEBHOOK_ID/chat
N8N_MOBILE_CHAT_URL=https://your-n8n-instance/webhook/YOUR_MOBILE_WEBHOOK_ID/chat
N8N_API_KEY=

# ── Email ─────────────────────────────────────────────────────────────────────
# Option A — Gmail SMTP (use an App Password, NOT your real Gmail password)
#   Google Account → Security → 2-Step Verification → App Passwords
SMTP_USER=REPLACE_ME@gmail.com
SMTP_PASS=REPLACE_ME
SMTP_FROM=REPLACE_ME@gmail.com
# Option B — Resend HTTP API
# SMTP_USER=resend
# SMTP_PASS=re_your_resend_api_key
# SMTP_FROM=onboarding@resend.dev
SKIP_EMAIL_VERIFICATION=false

# ── GitHub (optional) ─────────────────────────────────────────────────────────
GITHUB_TOKEN=REPLACE_ME
GITHUB_OWNER=REPLACE_ME
GITHUB_REPO=REPLACE_ME
GITHUB_BRANCH=main

# GitHub OAuth App (optional — for per-user GitHub account linking)
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# ── FTP (optional — for WordPress deployment) ─────────────────────────────────
FTP_HOST=REPLACE_ME
FTP_USER=REPLACE_ME
FTP_PASS=REPLACE_ME
FTP_REMOTE_PATH=/wp-content/themes

# ── Cloudflare Tunnel (optional — for public HTTPS access) ────────────────────
# Get token from: one.dash.cloudflare.com → Zero Trust → Networks → Tunnels
# Leave blank to disable the cloudflared container
CLOUDFLARE_TUNNEL_TOKEN=
